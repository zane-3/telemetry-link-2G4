  45:App/Src/app_crsf.c **** void AppCrsf_SendFailsafe(UART_HandleTypeDef *uart)
  46:App/Src/app_crsf.c **** {
  47:App/Src/app_crsf.c ****   uint16_t failsafe_channels[APP_CRSF_CHANNEL_COUNT];
  48:App/Src/app_crsf.c ****   uint8_t i;
  49:App/Src/app_crsf.c **** 
  50:App/Src/app_crsf.c ****   // CH1 Roll = 992 (mid)
  51:App/Src/app_crsf.c ****   failsafe_channels[0] = APP_CRSF_CHANNEL_MID;
  52:App/Src/app_crsf.c ****   // CH2 Pitch = 992 (mid)
  53:App/Src/app_crsf.c ****   failsafe_channels[1] = APP_CRSF_CHANNEL_MID;
  54:App/Src/app_crsf.c ****   // CH3 Throttle = 172 (min)
  55:App/Src/app_crsf.c ****   failsafe_channels[2] = APP_CRSF_CHANNEL_MIN;
  56:App/Src/app_crsf.c ****   // CH4 Yaw = 992 (mid)
  57:App/Src/app_crsf.c ****   failsafe_channels[3] = APP_CRSF_CHANNEL_MID;
  58:App/Src/app_crsf.c ****   // CH5 Arm = 172 (disarm)
  59:App/Src/app_crsf.c ****   failsafe_channels[4] = APP_CRSF_CHANNEL_MIN;
  60:App/Src/app_crsf.c ****   // CH6-16 = 992 (mid)
  61:App/Src/app_crsf.c ****   for (i = 5; i < APP_CRSF_CHANNEL_COUNT; i++)
  62:App/Src/app_crsf.c ****   {
  63:App/Src/app_crsf.c ****     failsafe_channels[i] = APP_CRSF_CHANNEL_MID;
  64:App/Src/app_crsf.c ****   }
  65:App/Src/app_crsf.c **** 
  66:App/Src/app_crsf.c ****   AppCrsf_SendRcChannels(uart, failsafe_channels);
  67:App/Src/app_crsf.c **** }
