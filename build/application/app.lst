 829:App/Src/app.c **** static bool App_TryHandleHostConfigByte(uint8_t byte)
 830:App/Src/app.c **** {
 831:App/Src/app.c ****   const uint8_t prefix[] = {'+', '+', '+'};
 832:App/Src/app.c **** 
 833:App/Src/app.c ****   // Check for +++ prefix to enter config mode
 834:App/Src/app.c ****   if (!g_app.cfg_mode_active)
 835:App/Src/app.c ****   {
