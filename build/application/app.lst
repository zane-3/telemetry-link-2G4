 456:App/Src/app.c ****   for (index = 0U; index < (sizeof(baudrates) / sizeof(baudrates[0])); ++index)
 457:App/Src/app.c ****   {
 458:App/Src/app.c ****     duplicate = false;
 459:App/Src/app.c ****     for (previous = 0U; previous < index; ++previous)
 460:App/Src/app.c ****     {
 461:App/Src/app.c ****       if (baudrates[previous] == baudrates[index])
 462:App/Src/app.c ****       {
 463:App/Src/app.c ****         duplicate = true;
 464:App/Src/app.c ****         break;
 465:App/Src/app.c ****       }
 466:App/Src/app.c ****     }
 467:App/Src/app.c ****     if (duplicate)
 468:App/Src/app.c ****     {
 469:App/Src/app.c ****       continue;
 470:App/Src/app.c ****     }
 471:App/Src/app.c **** 
 472:App/Src/app.c ****     if (App_EnterRadioCommandMode(baudrates[index], forward_to_host))
 473:App/Src/app.c ****     {
 474:App/Src/app.c ****       *active_baudrate = baudrates[index];
 475:App/Src/app.c ****       return true;
 476:App/Src/app.c ****     }
 477:App/Src/app.c ****   }
 478:App/Src/app.c **** 
 479:App/Src/app.c ****   return false;
 480:App/Src/app.c **** }
