 333:App/Src/app.c **** static bool App_RadioConfigStorageIsValid(const app_radio_runtime_config_t *config)
 334:App/Src/app.c **** {
 335:App/Src/app.c ****   if (config == NULL)
 336:App/Src/app.c ****   {
 337:App/Src/app.c ****     return false;
 338:App/Src/app.c ****   }
 339:App/Src/app.c ****   if ((config->magic != APP_RADIO_CONFIG_FLASH_MAGIC) ||
 340:App/Src/app.c ****       (config->version != APP_RADIO_CONFIG_FLASH_VERSION))
 341:App/Src/app.c ****   {
 342:App/Src/app.c ****     return false;
 343:App/Src/app.c ****   }
 344:App/Src/app.c ****   if ((config->role != APP_RADIO_ROLE_MASTER) &&
 345:App/Src/app.c ****       (config->role != APP_RADIO_ROLE_SLAVE))
 346:App/Src/app.c ****   {
 347:App/Src/app.c ****     return false;
 348:App/Src/app.c ****   }
 349:App/Src/app.c ****   if ((config->local_id < 1U) || (config->local_id > 0xFEU) ||
 350:App/Src/app.c ****       (config->remote_id < 1U) || (config->remote_id > 0xFEU) ||
 351:App/Src/app.c ****       (config->channel > 0xFFU) ||
 352:App/Src/app.c ****       (config->option > 0xFFU) ||
 353:App/Src/app.c ****       (config->filter_enable > 1U) ||
 354:App/Src/app.c ****       (config->ack_enable > 1U))
 355:App/Src/app.c ****   {
 356:App/Src/app.c ****     return false;
 357:App/Src/app.c ****   }
 358:App/Src/app.c ****   return config->crc == App_RadioConfigCrc(config);
 359:App/Src/app.c **** }
