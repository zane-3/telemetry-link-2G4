 487:App/Src/app.c ****   App_ReadRadioFor(APP_RADIO_CONFIG_GUARD_WAIT_MS, false);
 488:App/Src/app.c ****   return App_QueryRadioConfig(forward_to_host);
 489:App/Src/app.c **** }
 490:App/Src/app.c **** 
 491:App/Src/app.c **** static bool App_QueryRadioConfig(bool forward_to_host)
 492:App/Src/app.c **** {
 493:App/Src/app.c ****   const uint8_t read_command[] = {0xC1U, 0xC1U, 0xC1U};
 494:App/Src/app.c **** 
 495:App/Src/app.c ****   App_SendRadioBytes(read_command, (uint16_t)sizeof(read_command));
 496:App/Src/app.c ****   App_ReadRadioFor(APP_RADIO_CONFIG_VIEW_WAIT_MS, false);
 497:App/Src/app.c ****   if (App_E28ResponseHasParameters())
 498:App/Src/app.c ****   {
 499:App/Src/app.c ****     if (forward_to_host)
 500:App/Src/app.c ****     {
 501:App/Src/app.c ****       App_WriteHostHexDump(g_app.radio_config_bytes, g_app.radio_config_length);
 502:App/Src/app.c ****     }
 503:App/Src/app.c ****     return true;
 504:App/Src/app.c ****   }
 505:App/Src/app.c ****   return false;
 506:App/Src/app.c **** }
 507:App/Src/app.c **** 
 508:App/Src/app.c **** static bool App_E28WriteConfig(bool forward_to_host)
 509:App/Src/app.c **** {
 510:App/Src/app.c ****   uint8_t frame[6];
 511:App/Src/app.c **** 
 512:App/Src/app.c ****   // 步骤1：发送配置命令（0xC0）
ARM GAS  C:\Users\PC\AppData\Local\Temp\ccarrw6m.s 			page 65


 513:App/Src/app.c ****   App_E28BuildConfigFrame(0xC0U, frame);
 514:App/Src/app.c ****   App_SendRadioBytes(frame, (uint16_t)sizeof(frame));
 515:App/Src/app.c ****   App_ReadRadioFor(APP_RADIO_CONFIG_CMD_WAIT_MS, false);
 516:App/Src/app.c **** 
 517:App/Src/app.c ****   if (!App_E28ResponseMatchesConfig())
 518:App/Src/app.c ****   {
 519:App/Src/app.c ****     if (g_app.hw.host_uart1 != NULL)
 520:App/Src/app.c ****     {
 521:App/Src/app.c ****       App_WriteHostString("E28 WRITE CONFIG FAILED\r\n");
 522:App/Src/app.c ****     }
 523:App/Src/app.c ****     return false;
 524:App/Src/app.c ****   }
 525:App/Src/app.c **** 
 526:App/Src/app.c ****   if (g_app.hw.host_uart1 != NULL)
 527:App/Src/app.c ****   {
 528:App/Src/app.c ****     App_WriteHostString("E28 WRITE CONFIG OK\r\n");
 529:App/Src/app.c ****   }
 530:App/Src/app.c **** 
 531:App/Src/app.c ****   // 步骤2：发送保存命令（0xC2）保存到Flash
 532:App/Src/app.c ****   frame[0] = 0xC2U;  // SAVE command
 533:App/Src/app.c ****   frame[1] = 0xC2U;
 534:App/Src/app.c ****   frame[2] = 0xC2U;
 535:App/Src/app.c ****   App_SendRadioBytes(frame, 3);
 536:App/Src/app.c ****   HAL_Delay(200);  // 等待保存完成
 537:App/Src/app.c **** 
 538:App/Src/app.c ****   if (g_app.hw.host_uart1 != NULL)
 539:App/Src/app.c ****   {
 540:App/Src/app.c ****     App_WriteHostString("E28 SAVE SENT\r\n");
 541:App/Src/app.c ****   }
 542:App/Src/app.c **** 
 543:App/Src/app.c ****   // 步骤3：复位模块使配置生效
 544:App/Src/app.c ****   frame[0] = 0xC3U;  // RESET command
 545:App/Src/app.c ****   frame[1] = 0xC3U;
 546:App/Src/app.c ****   frame[2] = 0xC3U;
 547:App/Src/app.c ****   App_SendRadioBytes(frame, 3);
 548:App/Src/app.c ****   HAL_Delay(1000);  // 等待复位完成（增加到1秒）
 549:App/Src/app.c **** 
 550:App/Src/app.c ****   if (g_app.hw.host_uart1 != NULL)
 551:App/Src/app.c ****   {
 552:App/Src/app.c ****     App_WriteHostString("E28 RESET SENT\r\n");
 553:App/Src/app.c ****   }
 554:App/Src/app.c **** 
 555:App/Src/app.c ****   if (forward_to_host)
 556:App/Src/app.c ****   {
 557:App/Src/app.c ****     App_WriteHostHexDump(g_app.radio_config_bytes, g_app.radio_config_length);
 558:App/Src/app.c ****   }
 559:App/Src/app.c **** 
 560:App/Src/app.c ****   return true;
 561:App/Src/app.c **** }
 562:App/Src/app.c **** 
 563:App/Src/app.c **** static void App_E28BuildConfigFrame(uint8_t head, uint8_t frame[6])
 564:App/Src/app.c **** {
 565:App/Src/app.c ****   const uint16_t address = App_E28LocalAddress();
 566:App/Src/app.c **** 
 567:App/Src/app.c ****   frame[0] = head;
 568:App/Src/app.c ****   frame[1] = (uint8_t)(address >> 8);
 569:App/Src/app.c ****   frame[2] = (uint8_t)(address & 0xFFU);
ARM GAS  C:\Users\PC\AppData\Local\Temp\ccarrw6m.s 			page 66


 570:App/Src/app.c ****   frame[3] = (uint8_t)((APP_RADIO_E28_UART_BAUD_BITS << 3) | APP_RADIO_E28_AIR_RATE_BITS);
 571:App/Src/app.c ****   frame[4] = (uint8_t)g_app.radio_config.channel;
 572:App/Src/app.c ****   frame[5] = (uint8_t)g_app.radio_config.option;
 573:App/Src/app.c **** }
 574:App/Src/app.c **** 
 575:App/Src/app.c **** static uint16_t App_E28LocalAddress(void)
