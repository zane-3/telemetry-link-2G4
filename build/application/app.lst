 482:App/Src/app.c **** static bool App_EnterRadioCommandMode(uint32_t baudrate, bool forward_to_host)
 483:App/Src/app.c **** {
 484:App/Src/app.c ****   App_ConfigureRadioCommandMode();
 485:App/Src/app.c ****   (void)App_SetUartBaudrate(g_app.hw.radio_uart, baudrate);
