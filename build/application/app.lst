 426:App/Src/app.c **** static bool App_FindRadioCommandBaudrate(uint32_t *active_baudrate, bool forward_to_host)
 427:App/Src/app.c **** {
 428:App/Src/app.c ****   static const uint32_t baudrates[] = {
 429:App/Src/app.c ****       APP_RADIO_DEFAULT_BAUDRATE,
 430:App/Src/app.c ****   };
 431:App/Src/app.c ****   size_t index;
 432:App/Src/app.c ****   size_t previous;
 433:App/Src/app.c ****   bool duplicate;
 434:App/Src/app.c **** 
 435:App/Src/app.c ****   if (active_baudrate == NULL)
 436:App/Src/app.c ****   {
 437:App/Src/app.c ****     return false;
 438:App/Src/app.c ****   }
 439:App/Src/app.c **** 
 440:App/Src/app.c ****   for (index = 0U; index < (sizeof(baudrates) / sizeof(baudrates[0])); ++index)
 441:App/Src/app.c ****   {
 442:App/Src/app.c ****     duplicate = false;
 443:App/Src/app.c ****     for (previous = 0U; previous < index; ++previous)
 444:App/Src/app.c ****     {
 445:App/Src/app.c ****       if (baudrates[previous] == baudrates[index])
 446:App/Src/app.c ****       {
 447:App/Src/app.c ****         duplicate = true;
 448:App/Src/app.c ****         break;
 449:App/Src/app.c ****       }
 450:App/Src/app.c ****     }
 451:App/Src/app.c ****     if (duplicate)
 452:App/Src/app.c ****     {
 453:App/Src/app.c ****       continue;
 454:App/Src/app.c ****     }
 455:App/Src/app.c **** 
ARM GAS  C:\Users\PC\AppData\Local\Temp\cciaJqTl.s 			page 64


 456:App/Src/app.c ****     if (App_EnterRadioCommandMode(baudrates[index], forward_to_host))
 457:App/Src/app.c ****     {
 458:App/Src/app.c ****       *active_baudrate = baudrates[index];
 459:App/Src/app.c ****       return true;
 460:App/Src/app.c ****     }
 461:App/Src/app.c ****   }
 462:App/Src/app.c **** 
 463:App/Src/app.c ****   return false;
 464:App/Src/app.c **** }
 465:App/Src/app.c **** 
 466:App/Src/app.c **** static bool App_EnterRadioCommandMode(uint32_t baudrate, bool forward_to_host)
 467:App/Src/app.c **** {
 468:App/Src/app.c ****   App_ConfigureRadioCommandMode();
 469:App/Src/app.c ****   (void)App_SetUartBaudrate(g_app.hw.radio_uart, baudrate);
 470:App/Src/app.c ****   App_ClearRadioInput();
 471:App/Src/app.c ****   App_ReadRadioFor(APP_RADIO_CONFIG_GUARD_WAIT_MS, false);
 472:App/Src/app.c ****   return App_QueryRadioConfig(forward_to_host);
 473:App/Src/app.c **** }
 474:App/Src/app.c **** 
 475:App/Src/app.c **** static bool App_QueryRadioConfig(bool forward_to_host)
 476:App/Src/app.c **** {
 477:App/Src/app.c ****   const uint8_t read_command[] = {0xC1U, 0xC1U, 0xC1U};
 478:App/Src/app.c **** 
 479:App/Src/app.c ****   App_SendRadioBytes(read_command, (uint16_t)sizeof(read_command));
 480:App/Src/app.c ****   App_ReadRadioFor(APP_RADIO_CONFIG_VIEW_WAIT_MS, false);
 481:App/Src/app.c ****   if (App_E28ResponseHasParameters())
 482:App/Src/app.c ****   {
 483:App/Src/app.c ****     if (forward_to_host)
 484:App/Src/app.c ****     {
 485:App/Src/app.c ****       App_WriteHostHexDump(g_app.radio_config_bytes, g_app.radio_config_length);
 486:App/Src/app.c ****     }
 487:App/Src/app.c ****     return true;
 488:App/Src/app.c ****   }
 489:App/Src/app.c ****   return false;
 490:App/Src/app.c **** }
 491:App/Src/app.c **** 
 492:App/Src/app.c **** static bool App_E28WriteConfig(bool forward_to_host)
 493:App/Src/app.c **** {
 494:App/Src/app.c ****   uint8_t frame[6];
 495:App/Src/app.c **** 
 496:App/Src/app.c ****   // 步骤1：发送配置命令（0xC0）
 497:App/Src/app.c ****   App_E28BuildConfigFrame(0xC0U, frame);
 498:App/Src/app.c ****   App_SendRadioBytes(frame, (uint16_t)sizeof(frame));
 499:App/Src/app.c ****   App_ReadRadioFor(APP_RADIO_CONFIG_CMD_WAIT_MS, false);
 500:App/Src/app.c **** 
 501:App/Src/app.c ****   if (!App_E28ResponseMatchesConfig())
 502:App/Src/app.c ****   {
 503:App/Src/app.c ****     if (g_app.hw.host_uart1 != NULL)
 504:App/Src/app.c ****     {
 505:App/Src/app.c ****       App_WriteHostString("E28 WRITE CONFIG FAILED\r\n");
 506:App/Src/app.c ****     }
 507:App/Src/app.c ****     return false;
 508:App/Src/app.c ****   }
 509:App/Src/app.c **** 
 510:App/Src/app.c ****   if (g_app.hw.host_uart1 != NULL)
 511:App/Src/app.c ****   {
 512:App/Src/app.c ****     App_WriteHostString("E28 WRITE CONFIG OK\r\n");
ARM GAS  C:\Users\PC\AppData\Local\Temp\cciaJqTl.s 			page 65


 513:App/Src/app.c ****   }
 514:App/Src/app.c **** 
 515:App/Src/app.c ****   // 步骤2：发送保存命令（0xC2）保存到Flash
 516:App/Src/app.c ****   frame[0] = 0xC2U;  // SAVE command
 517:App/Src/app.c ****   frame[1] = 0xC2U;
 518:App/Src/app.c ****   frame[2] = 0xC2U;
 519:App/Src/app.c ****   App_SendRadioBytes(frame, 3);
 520:App/Src/app.c ****   HAL_Delay(200);  // 等待保存完成
 521:App/Src/app.c **** 
 522:App/Src/app.c ****   if (g_app.hw.host_uart1 != NULL)
 523:App/Src/app.c ****   {
 524:App/Src/app.c ****     App_WriteHostString("E28 SAVE SENT\r\n");
 525:App/Src/app.c ****   }
 526:App/Src/app.c **** 
 527:App/Src/app.c ****   // 步骤3：复位模块使配置生效
 528:App/Src/app.c ****   frame[0] = 0xC3U;  // RESET command
 529:App/Src/app.c ****   frame[1] = 0xC3U;
 530:App/Src/app.c ****   frame[2] = 0xC3U;
 531:App/Src/app.c ****   App_SendRadioBytes(frame, 3);
 532:App/Src/app.c ****   HAL_Delay(1000);  // 等待复位完成（增加到1秒）
 533:App/Src/app.c **** 
 534:App/Src/app.c ****   if (g_app.hw.host_uart1 != NULL)
 535:App/Src/app.c ****   {
 536:App/Src/app.c ****     App_WriteHostString("E28 RESET SENT\r\n");
 537:App/Src/app.c ****   }
 538:App/Src/app.c **** 
 539:App/Src/app.c ****   if (forward_to_host)
 540:App/Src/app.c ****   {
 541:App/Src/app.c ****     App_WriteHostHexDump(g_app.radio_config_bytes, g_app.radio_config_length);
 542:App/Src/app.c ****   }
 543:App/Src/app.c **** 
 544:App/Src/app.c ****   return true;
 545:App/Src/app.c **** }
 546:App/Src/app.c **** 
 547:App/Src/app.c **** static void App_E28BuildConfigFrame(uint8_t head, uint8_t frame[6])
 548:App/Src/app.c **** {
 549:App/Src/app.c ****   const uint16_t address = App_E28LocalAddress();
 550:App/Src/app.c **** 
 551:App/Src/app.c ****   frame[0] = head;
 552:App/Src/app.c ****   frame[1] = (uint8_t)(address >> 8);
 553:App/Src/app.c ****   frame[2] = (uint8_t)(address & 0xFFU);
 554:App/Src/app.c ****   frame[3] = (uint8_t)((APP_RADIO_E28_UART_BAUD_BITS << 3) | APP_RADIO_E28_AIR_RATE_BITS);
 555:App/Src/app.c ****   frame[4] = (uint8_t)g_app.radio_config.channel;
 556:App/Src/app.c ****   frame[5] = (uint8_t)g_app.radio_config.option;
 557:App/Src/app.c **** }
 558:App/Src/app.c **** 
 559:App/Src/app.c **** static uint16_t App_E28LocalAddress(void)
 560:App/Src/app.c **** {
 561:App/Src/app.c ****   if (App_RadioRoleIsMaster())
 562:App/Src/app.c ****   {
 563:App/Src/app.c ****     return (uint16_t)APP_RADIO_MASTER_ADDRESS;
 564:App/Src/app.c ****   }
 565:App/Src/app.c ****   return (uint16_t)(APP_RADIO_SLAVE_BASE_ADDR + g_app.radio_config.local_id);
 566:App/Src/app.c **** }
