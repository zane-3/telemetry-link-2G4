 445:App/Src/app.c ****       APP_RADIO_DEFAULT_BAUDRATE,
 446:App/Src/app.c ****   };
 447:App/Src/app.c ****   size_t index;
 448:App/Src/app.c ****   size_t previous;
 449:App/Src/app.c ****   bool duplicate;
 450:App/Src/app.c **** 
 451:App/Src/app.c ****   if (active_baudrate == NULL)
 452:App/Src/app.c ****   {
 453:App/Src/app.c ****     return false;
