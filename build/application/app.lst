 837:App/Src/app.c ****     {
 838:App/Src/app.c ****       g_app.cfg_mode_prefix_index++;
 839:App/Src/app.c ****       if (g_app.cfg_mode_prefix_index >= sizeof(prefix))
 840:App/Src/app.c ****       {
 841:App/Src/app.c ****         g_app.cfg_mode_active = true;
 842:App/Src/app.c ****         g_app.cfg_mode_deadline_ms = HAL_GetTick() + APP_HOST_CFG_MODE_TIMEOUT_MS;
 843:App/Src/app.c ****         g_app.cfg_mode_prefix_index = 0;
 844:App/Src/app.c ****         g_app.host_cfg_command_length = 0;
 845:App/Src/app.c ****         App_WriteHostString("OK CFG MODE\r\n");
 846:App/Src/app.c ****       }
 847:App/Src/app.c ****       return true;
 848:App/Src/app.c ****     }
 849:App/Src/app.c ****     else
 850:App/Src/app.c ****     {
 851:App/Src/app.c ****       // Not the prefix, forward accumulated '+' and current byte
 852:App/Src/app.c ****       for (uint8_t i = 0; i < g_app.cfg_mode_prefix_index; i++)
 853:App/Src/app.c ****       {
 854:App/Src/app.c ****         App_ForwardHostByte(prefix[i]);
 855:App/Src/app.c ****       }
 856:App/Src/app.c ****       g_app.cfg_mode_prefix_index = 0;
 857:App/Src/app.c **** 
 858:App/Src/app.c ****       // Forward current byte as well
 859:App/Src/app.c ****       App_ForwardHostByte(byte);
 860:App/Src/app.c ****       return true;
 861:App/Src/app.c ****     }
 862:App/Src/app.c ****   }
