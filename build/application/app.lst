 228:App/Src/app.c ****   {
 229:App/Src/app.c ****     App_ServiceWatchdog();
 230:App/Src/app.c ****     AppFrameworkLed_Update(&g_app.sys_led, true, APP_SYS_LED_TOGGLE_MS, HAL_GetTick());
 231:App/Src/app.c ****     if ((g_app.hw.radio_aux_port != NULL) &&
 232:App/Src/app.c ****         (HAL_GPIO_ReadPin(g_app.hw.radio_aux_port, g_app.hw.radio_aux_pin) == GPIO_PIN_SET))
 233:App/Src/app.c ****     {
 234:App/Src/app.c ****       break;
 235:App/Src/app.c ****     }
 236:App/Src/app.c ****   }
 237:App/Src/app.c **** }
