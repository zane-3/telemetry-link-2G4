 667:App/Src/app.c **** static void App_WriteHostHexDump(const uint8_t *bytes, uint16_t length)
 668:App/Src/app.c **** {
 669:App/Src/app.c ****   static const char hex[] = "0123456789ABCDEF";
 670:App/Src/app.c ****   uint16_t index;
 671:App/Src/app.c ****   char out[4];
 672:App/Src/app.c **** 
 673:App/Src/app.c ****   if (bytes == NULL)
 674:App/Src/app.c ****   {
 675:App/Src/app.c ****     return;
 676:App/Src/app.c ****   }
 677:App/Src/app.c **** 
 678:App/Src/app.c ****   for (index = 0U; index < length; ++index)
 679:App/Src/app.c ****   {
 680:App/Src/app.c ****     out[0] = hex[(bytes[index] >> 4) & 0x0FU];
 681:App/Src/app.c ****     out[1] = hex[bytes[index] & 0x0FU];
 682:App/Src/app.c ****     out[2] = (index + 1U == length) ? '\r' : ' ';
 683:App/Src/app.c ****     out[3] = (index + 1U == length) ? '\n' : '\0';
 684:App/Src/app.c ****     App_WriteBytes(g_app.hw.host_uart1, (const uint8_t *)out, (uint16_t)((index + 1U == length) ? 4
 685:App/Src/app.c ****   }
 686:App/Src/app.c **** }
