1369:../Drivers/CMSIS/Include/core_cm3.h **** */
1370:../Drivers/CMSIS/Include/core_cm3.h **** #define _FLD2VAL(field, value)    (((uint32_t)(value) & field ## _Msk) >> field ## _Pos)
