 404:App/Src/app.c **** static void App_WriteRadioConfigStorage(bool marker_written)
 405:App/Src/app.c **** {
 406:App/Src/app.c ****   FLASH_EraseInitTypeDef erase;
 407:App/Src/app.c ****   uint32_t page_error = 0U;
 408:App/Src/app.c ****   app_radio_runtime_config_t config = g_app.radio_config;
 409:App/Src/app.c ****   const uint32_t *values = (const uint32_t *)&config;
 410:App/Src/app.c ****   uint32_t address = APP_RADIO_CONFIG_MARKER_ADDR;
 411:App/Src/app.c ****   uint32_t index;
 412:App/Src/app.c **** 
 413:App/Src/app.c ****   if (marker_written && App_RadioConfigMarkerIsWritten())
 414:App/Src/app.c ****   {
 415:App/Src/app.c ****     return;
 416:App/Src/app.c ****   }
 417:App/Src/app.c **** 
 418:App/Src/app.c ****   config.magic = APP_RADIO_CONFIG_FLASH_MAGIC;
 419:App/Src/app.c ****   config.version = APP_RADIO_CONFIG_FLASH_VERSION;
 420:App/Src/app.c ****   config.marker = marker_written ? App_RadioConfigMarkerValue() : 0xFFFFFFFFU;
 421:App/Src/app.c ****   config.crc = App_RadioConfigCrc(&config);
 422:App/Src/app.c **** 
 423:App/Src/app.c ****   HAL_FLASH_Unlock();
 424:App/Src/app.c ****   erase.TypeErase = FLASH_TYPEERASE_PAGES;
 425:App/Src/app.c ****   erase.PageAddress = APP_RADIO_CONFIG_MARKER_ADDR;
 426:App/Src/app.c ****   erase.NbPages = 1U;
 427:App/Src/app.c ****   if (HAL_FLASHEx_Erase(&erase, &page_error) == HAL_OK)
 428:App/Src/app.c ****   {
 429:App/Src/app.c ****     for (index = 0U; index < (sizeof(config) / sizeof(uint32_t)); ++index)
 430:App/Src/app.c ****     {
 431:App/Src/app.c ****       if (HAL_FLASH_Program(FLASH_TYPEPROGRAM_WORD, address, values[index]) != HAL_OK)
 432:App/Src/app.c ****       {
 433:App/Src/app.c ****         break;
 434:App/Src/app.c ****       }
 435:App/Src/app.c ****       address += 4U;
 436:App/Src/app.c ****     }
 437:App/Src/app.c ****   }
 438:App/Src/app.c ****   HAL_FLASH_Lock();
 439:App/Src/app.c ****   g_app.radio_config = config;
 440:App/Src/app.c **** }
